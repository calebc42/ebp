    },
    "-32600": {
      "kind": "invalid-request",
      "meaning": "JSON-RPC Invalid Request"
    },
    "-32601": {
      "kind": "method-not-found",
      "meaning": "JSON-RPC Method not found"
    },
    "-32602": {
      "kind": "invalid-params",
      "meaning": "JSON-RPC Invalid params"
    },
    "-32603": {
      "kind": "internal-error",
      "meaning": "JSON-RPC Internal error"
    },
    "1001": {
      "kind": "cap-unsupported",
      "meaning": "Capability was not advertised or is unavailable"
    },
    "1002": {
      "kind": "cap-permission",
      "meaning": "User or platform permission is required"
    },
    "1003": {
      "kind": "cap-failed",
      "meaning": "Advertised capability failed"
    },
    "1101": {
      "kind": "triggers-rejected",
      "meaning": "Trigger replace-set was rejected atomically"
    },
    "1200": {
      "kind": "not-authenticated",
      "meaning": "Method is not legal before authentication"
    },
    "1201": {
      "kind": "content-invalid",
      "meaning": "Structurally valid params contain an invalid surface, node, action, or module object"
    },
    "1202": {
      "kind": "protocol-version",
      "meaning": "No compatible protocol major version exists"
    },
    "1203": {
      "kind": "auth-failed",
      "meaning": "Authentication proof failed"
    },
    "1204": {
      "kind": "session-state",
      "meaning": "Method is not legal in the current session state"
    },
    "1301": {
      "kind": "request-cancelled",
      "meaning": "Request was cancelled"
    },
    "1400": {
      "kind": "frame-too-large",
      "meaning": "Frame exceeds the header or body size cap; diagnostic-only, see Section 6.2"
    },
    "1401": {
      "kind": "overloaded",
      "meaning": "Bounded processing capacity was exhausted"
    },
    "1500": {
      "kind": "event-retry",
      "meaning": "Event could not be accepted yet and remains eligible for retry"
    },
    "1600": {
      "kind": "queue-busy",
      "meaning": "A queue replay is already active"
    },
    "1601": {
      "kind": "queue-full",
      "meaning": "Durable queue capacity is exhausted"
    }
  },
  "limits": {
    "fixed": {
      "max_header_bytes": 8192,
      "max_body_bytes": 4194304,
      "max_json_depth": 64,
      "max_nodes_per_snapshot": 10000,
      "max_children_per_node": 10000,
      "max_identifier_bytes": 128,
      "max_request_id_bytes": 64
    },
    "welcome": {
      "max_frame_bytes": {"requirement": "required", "exact": 4194304},
      "max_queued_events": {"requirement": "required", "min": 256},
      "max_queued_bytes": {"requirement": "required", "min": 8388608},
      "max_event_bytes": {"requirement": "required", "min": 262144, "max_expr": "max_frame_bytes - 256"},
      "max_surfaces": {"requirement": "required", "min": 16},
      "max_surface_ids": {"requirement": "required", "min": 1024},
      "max_field_bytes": {"requirement": "required", "min": 65536, "max_expr": "max_frame_bytes - 2048"},
      "max_input_state_bytes": {"requirement": "required", "min": 262144},
      "max_capture_fields": {"requirement": "required", "min": 64},
      "max_triggers": {"requirement": "when triggers granted"},
      "max_trigger_responses": {"requirement": "when triggers granted"},
      "max_reminders": {"requirement": "when reminders.owner granted"},
      "max_editor_sessions": {"requirement": "when editor.sync granted"},
      "max_dialogs": {"requirement": "when surfaces.dialog granted"},
      "max_pie_menus": {"requirement": "when presentation.pie-menu granted", "min": 1},
      "max_device_report_bytes": {"requirement": "when capabilities or triggers granted"},
      "max_image_bytes": {"requirement": "when image advertised"},
      "max_decoded_image_bytes": {"requirement": "when image advertised"},
      "max_image_pixels": {"requirement": "when image advertised"},
      "max_canvas_ops": {"requirement": "when canvas advertised"},
      "max_chart_points": {"requirement": "when chart advertised"},
      "max_rich_spans": {"requirement": "when rich_text advertised"},
      "max_table_cells": {"requirement": "when table advertised"},
      "max_shortcut_icon_bytes": {"requirement": "when shortcut.pin or shortcuts.set advertised"},
      "max_shortcuts": {"requirement": "when shortcuts.set advertised"}
    }
  },
