  "error_codes": {
    "-32700": {
      "kind": "parse-error",
      "context": "unparseable frame"
    },
    "-32600": {
      "kind": "invalid-request",
      "context": "not JSON-RPC 2.0 / prohibited batch / wrong direction or class"
    },
    "-32601": {
      "kind": "method-not-found",
      "context": "unknown request method"
    },
    "-32602": {
      "kind": "invalid-params",
      "context": "JSON-RPC standard set, reserved"
    },
    "-32603": {
      "kind": "internal",
      "context": "handler signalled"
    },
    "1001": {
      "kind": "cap-unsupported",
      "context": "capability.invoke"
    },
    "1002": {
      "kind": "cap-permission",
      "context": "capability.invoke; remedy rides data (perm, settings)"
    },
    "1003": {
      "kind": "cap-failed",
      "context": "capability.invoke"
    },
    "1101": {
      "kind": "triggers-rejected",
      "context": "triggers.set wholesale rejection"
    },
    "1200": {
      "kind": "not-authenticated",
      "context": "any method before the proof completes"
    },
    "1201": {
      "kind": "spec-invalid",
      "context": "malformed params"
    },
    "1202": {
      "kind": "proto-version",
      "context": "protocol mismatch at hello"
    },
    "1203": {
      "kind": "auth-failed",
      "context": "bad MAC"
    },
    "1301": {
      "kind": "request-cancelled",
      "context": "the answer to a cancelled request"
    },
    "1400": {
      "kind": "frame-too-large",
      "context": "frame-cap refusal, rides log.error"
    },
    "1401": {
      "kind": "overloaded",
      "context": "bounded-queue exhaustion, rides log.error"
    }
  },
