  "methods": {
    "session.hello": {
      "sender": "emacs",
      "class": "request",
      "states": ["CONNECTED"],
      "capability": "core",
      "params": {
        "required": ["protocol", "client", "pairing_id", "client_nonce", "wants"],
        "optional": []
      },
      "result": {
        "required": ["server_nonce"],
        "optional": []
      },
      "errors": [1202, -32602]
    },
    "auth.response": {
      "sender": "emacs",
      "class": "request",
      "states": ["CHALLENGED"],
      "capability": "core",
      "params": {
        "required": ["pairing_id", "client_nonce", "server_nonce", "client_proof"],
        "optional": []
      },
      "result": {
        "required": ["server_proof", "protocol", "server", "granted", "surface_profiles", "surfaces", "queued_events", "limits"],
        "optional": ["input_state", "device"]
      },
      "errors": [1203, -32602]
    },
    "session.ready": {
      "sender": "emacs",
      "class": "request",
      "states": ["SYNCING"],
      "capability": "core",
      "params": {
