      "optional": ["on_tap", "selected", "icon", "enabled"]
    },
    "assist_chip": {
      "required": ["label"],
      "optional": ["on_tap", "icon", "enabled"]
    },
    "menu": {
      "required": ["items"],
      "optional": ["icon", "enabled"]
    },
    "text_input": {
      "required": ["id"],
      "optional": ["value", "hint", "label", "on_change", "on_submit", "single_line", "min_lines", "max_lines", "monospace", "syntax", "password", "keyboard", "autofocus", "clear_on_submit", "enabled"]
